# ============ DATABASE ============
# Lấy từ Neon Console → Connection Details → Connection string
# KHÔNG bao giờ commit file .env lên Git!
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ============ JWT ============
# Tạo chuỗi ngẫu nhiên 32+ ký tự (vd: openssl rand -hex 32)
JWT_SECRET=replace-with-random-32-char-string
JWT_EXPIRES_IN=7d

# ============ APP ============
PORT=3000
COMPANY_DOMAIN=company
TIMEZONE=Asia/Ho_Chi_Minh

# Khung giờ check-in (24h format)
CHECKIN_START_HOUR=5
CHECKIN_END_HOUR=6

# Khoá đăng nhập
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_SECONDS=60

# ============ EMAIL (Gmail) ============
# Bắt buộc cho chức năng Thanh toán + Reset mật khẩu
# Bước 1: bật 2FA tại https://myaccount.google.com/security
# Bước 2: tạo App Password tại https://myaccount.google.com/apppasswords (chọn "Mail")
# Bước 3: dán password 16 ký tự (BỎ DẤU CÁCH) vào SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=abcdabcdabcdabcd
SMTP_FROM=5AM Check-in <your-email@gmail.com>
